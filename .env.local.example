# ─── AI & Embeddings ──────────────────────────────────────────────
# Gemini API Key for embedding fallback
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Fallback LLM ─────────────────────────────────────────────────
# Groq API Key for LLM completion
GROQ_API_KEY=your_groq_api_key_here
ENABLE_GROQ_FALLBACK=true

# ─── Vector Store ─────────────────────────────────────────────────
# Pinecone settings for RAG retrieval
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=cubot-cu
PINECONE_DIMENSION=768

# ─── Neon PostgreSQL Database ─────────────────────────────────────
# Connection string for Neon DB (PostgreSQL)
NEON_DATABASE_URL="postgresql://user:password@ep-something-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth Configuration ───────────────────────────────────────
# Base URL for NextAuth (e.g., production or local)
NEXTAUTH_URL="http://localhost:3000"
# Secret for signing JWTs
NEXTAUTH_SECRET="generate-a-strong-secret-key-here" # e.g. run: openssl rand -base64 32
# Admin username for dashboard
ADMIN_USERNAME="admin"
# Bcrypt hash of the admin password (use scripts/hash-password.ts to generate)
ADMIN_PASSWORD_HASH="$2a$12$somehash"

# ─── Rate Limiting (Upstash — free tier) ──────────────────────────
# Upstash Redis REST URL
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
# Upstash Redis REST Token
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── Public App Config ──────────────────────────────────────────────
# Base app URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_BOT_NAME="Cubot"
NEXT_PUBLIC_UNIVERSITY_NAME="Capital University"

# ─── Security Secrets ───────────────────────────────────────────────
# Secret used for Admin script execution or manual endpoints
ADMIN_SECRET="your-admin-secret"
# Secret used for chron jobs to trigger tasks securely
CRON_SECRET="your-cron-secret"

# ─── GitHub Actions (Crawl) ─────────────────────────────────────────
# GitHub Personal Access Token with repo actions access
GITHUB_TOKEN="ghp_some_token"
# GitHub repo format owner/repo
GITHUB_REPO="owner/repo"

# ─── Crawler Config ────────────────────────────────────────────────
# Maximum pages to crawl in one run
CRAWLER_MAX_PAGES="2500"
# Concurrency level for the crawler
CRAWLER_CONCURRENCY="4"
# Delay between requests in milliseconds
CRAWLER_DELAY_MS="900"
# Set to true for a dry-run (no DB writes)
DRY_RUN="false"
# Set to false to disable incremental crawling (always full scan)
INCREMENTAL="true"