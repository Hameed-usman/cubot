# ─── AI & Embeddings ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Fallback LLM ─────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
ENABLE_GROQ_FALLBACK=true

# ─── Vector Store ─────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=cubot-cu
PINECONE_DIMENSION=768

# ─── Rate Limiting (Upstash — free tier) ──────────────────────────
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# ─── Admin Security ───────────────────────────────────────────────
ADMIN_SECRET=your_very_long_random_secret_here

# ─── Public App Config ──────────────────────────────────────────────
NEXT_PUBLIC_UNIVERSITY_NAME=City University Peshawar
NEXT_PUBLIC_CHATBOT_NAME=Cubot
NEXT_PUBLIC_BASE_URL=https://cubot-cu.vercel.app