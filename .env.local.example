# ─── AI & Embeddings ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Fallback LLM ─────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
ENABLE_GROQ_FALLBACK=true

# ─── Vector Store ─────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=cubot-cu
PINECONE_DIMENSION=768

# ─── Neon PostgreSQL Database ─────────────────────────────────────
NEON_DATABASE_URL="postgresql://user:password@ep-something-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth Configuration ───────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-secret-key-here" # e.g. run: openssl rand -base64 32
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin_password_here"

# ─── Rate Limiting (Upstash — free tier) ──────────────────────────
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── Public App Config ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BOT_NAME="Cubot"
NEXT_PUBLIC_UNIVERSITY_NAME="Capital University"